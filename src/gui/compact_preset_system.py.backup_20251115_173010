from PySide6.QtWidgets import *
from PySide6.QtCore import *
from PySide6.QtGui import *

class CompactPresetSelector(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.current_selections = {
            "editing": "Balanced",
            "color": "Natural",  # No grading - ruins AI clips
            "effects": [],
            "transitions": [],
            "speed": "Constant"
        }
        self.setup_ui()

    def setup_ui(self):
        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(8)

        # CORRECT ORDER
        self.add_single_select(layout, "EDITING", "editing",
            ["Chill", "Balanced", "Dynamic", "Flash Cuts", "Hypercut", "EXTREME"])
        


        self.add_multi_select(layout, "BEAT EFFECTS", "effects",
            ["Beat Flash", "Camera Shake", "Zoom Pulse", "Video Glitch",
             "Chromatic Aberration", "Saturation Pulse", "Color Shift"])

        self.add_multi_select(layout, "TRANSITIONS", "transitions",
            ["Hard Cut", "Flash Wipe", "Dissolve", "Zoom Cut", "Glitch Cut", "Slide"])

        self.add_single_select(layout, "SPEED", "speed",
            ["Constant", "Dynamic", "Slow Motion", "Time Remap", "Beat-Sync Speed"])

        layout.addStretch()

    def add_single_select(self, layout, title, key, options):
        btn = QPushButton(f"{title}: {self.current_selections[key]}")
        btn.setFixedHeight(36)
        btn.setStyleSheet("""
            QPushButton {
                background: #1C2230;
                color: #B8C5D0;
                border: 1px solid #2F3541;
                border-radius: 6px;
                padding: 0 12px;
                text-align: left;
                font-size: 11px;
                font-weight: 600;
            }
            QPushButton:hover {
                background: #212936;
                border: 1px solid #00D9FF;
                color: #00D9FF;
            }
        """)
        btn.clicked.connect(lambda: self.show_single_menu(title, key, options, btn))
        layout.addWidget(btn)

    def add_multi_select(self, layout, title, key, options):
        selected = self.current_selections[key]
        count = len(selected)
        btn_text = f"{title}: {count} selected" if count > 0 else f"{title}: None"
        
        btn = QPushButton(btn_text)
        btn.setFixedHeight(36)
        btn.setStyleSheet("""
            QPushButton {
                background: #1C2230;
                color: #B8C5D0;
                border: 1px solid #2F3541;
                border-radius: 6px;
                padding: 0 12px;
                text-align: left;
                font-size: 11px;
                font-weight: 600;
            }
            QPushButton:hover {
                background: #212936;
                border: 1px solid #00D9FF;
                color: #00D9FF;
            }
        """)
        btn.clicked.connect(lambda: self.show_multi_menu(title, key, options, btn))
        layout.addWidget(btn)

    def show_single_menu(self, title, key, options, button):
        menu = QMenu(self)
        menu.setStyleSheet("""
            QMenu {
                background: #0F1419;
                border: 1px solid #00D9FF;
                border-radius: 6px;
                padding: 4px;
            }
            QMenu::item {
                background: transparent;
                color: #B8C5D0;
                padding: 8px 16px;
                border-radius: 4px;
            }
            QMenu::item:selected {
                background: #1C2230;
                color: #00D9FF;
            }
        """)

        for option in options:
            action = menu.addAction(option)
            if option == self.current_selections[key]:
                action.setCheckable(True)
                action.setChecked(True)
            action.triggered.connect(lambda checked, o=option: self.select_single(title, key, o, button))

        pos = button.mapToGlobal(button.rect().bottomLeft())
        menu.exec(pos)

    def show_multi_menu(self, title, key, options, button):
        menu = QMenu(self)
        menu.setStyleSheet("""
            QMenu {
                background: #0F1419;
                border: 1px solid #00D9FF;
                border-radius: 6px;
                padding: 4px;
            }
            QMenu::item {
                background: transparent;
                color: #B8C5D0;
                padding: 6px 16px;
                border-radius: 4px;
            }
            QMenu::item:selected {
                background: #1C2230;
                color: #00D9FF;
            }
        """)

        selected = self.current_selections[key]
        
        for option in options:
            action = menu.addAction(f"? {option}" if option in selected else f"? {option}")
            action.triggered.connect(lambda checked, o=option: self.toggle_multi(title, key, o, button))

        pos = button.mapToGlobal(button.rect().bottomLeft())
        menu.exec(pos)

    def select_single(self, title, key, option, button):
        backend_map = {
            "Cinematic Look": "Cinematic",
            "Cyberpunk Neon": "Cyberpunk",
            "Vintage Film": "Vintage",
            "High Contrast B&W": "High Contrast"
        }
        
        backend_value = backend_map.get(option, option)
        self.current_selections[key] = backend_value
        button.setText(f"{title}: {option}")
        print(f"? {key} = {backend_value}")

    def toggle_multi(self, title, key, option, button):
        selected = self.current_selections[key]
        
        if option in selected:
            selected.remove(option)
        else:
            selected.append(option)
        
        count = len(selected)
        btn_text = f"{title}: {count} selected" if count > 0 else f"{title}: None"
        button.setText(btn_text)
        
        print(f"? {key} = {selected}")

    def get_backend_effects(self):
        effect_map = {
            "Beat Flash": "beat_flash",
            "Camera Shake": "camera_shake",
            "Zoom Pulse": "zoom_pulse",
            "Video Glitch": "glitch",
            "Chromatic Aberration": "chromatic",
            "Saturation Pulse": "saturation_pulse",
            "Color Shift": "color_shift"
        }
        
        ui_effects = self.current_selections.get("effects", [])
        return [effect_map.get(e, e.lower().replace(" ", "_")) for e in ui_effects]

    def get_backend_transitions(self):
        trans_map = {
            "Hard Cut": "cut",
            "Flash Wipe": "flash",
            "Dissolve": "dissolve",
            "Zoom Cut": "zoom",
            "Glitch Cut": "glitch",
            "Slide": "slide"
        }
        
        ui_trans = self.current_selections.get("transitions", [])
        return [trans_map.get(t, t.lower()) for t in ui_trans]




