    def toggle_prompt_mode(self):
        is_custom = self.custom_mode.isChecked()
        self.vision_group.setVisible(is_custom)
    
    def generate_prompt_preview(self):
        print('\n' + '='*60)
        print('⚡ PREVIEWING AI DIRECTOR VISION')
        print('='*60)
        
        mode = 'Custom' if self.custom_mode.isChecked() else 'Auto'
        user_vision = self.vision_input.toPlainText().strip()
        
        # Get REAL data
        video_analyses = self._get_video_analyses()
        music_analysis = self._get_music_analysis()
        
        # Analyze what we actually have
        total_clips = len(video_analyses)
        subjects = {}
        styles = {}
        energies = []
        lipsync_clips = 0
        
        for data in video_analyses.values():
            # Count subjects
            subject = data.get('subject_type', 'unknown')
            subjects[subject] = subjects.get(subject, 0) + 1
            
            # Count styles
            style = data.get('art_style', 'unknown')
            styles[style] = styles.get(style, 0) + 1
            
            # Track energy
            energies.append(data.get('energy_level', 5))
            
            # Count lip sync suitable
            if data.get('lip_sync_suitable'):
                lipsync_clips += 1
        
        avg_energy = sum(energies) / len(energies) if energies else 5
        top_subject = max(subjects.items(), key=lambda x: x[1])[0] if subjects else 'unknown'
        top_style = max(styles.items(), key=lambda x: x[1])[0] if styles else 'unknown'
        
        bpm = music_analysis.get('tempo', 0)
        duration = music_analysis.get('duration', 0)
        
        if mode == 'Auto':
            preview = f"""AI Director will create an ultimate music video using:

📹 YOUR VIDEOS ({total_clips} clips):
   • Primary subject: {top_subject} ({subjects.get(top_subject, 0)} clips)
   • Art style: {top_style}
   • Average energy: {avg_energy:.1f}/10
   • Lip sync ready: {lipsync_clips} clips

🎵 YOUR MUSIC:
   • Tempo: {bpm:.1f} BPM
   • Duration: {duration:.1f}s
   • Structure: Analyzed

🎬 AI DIRECTOR'S PLAN:
Will sync {top_subject} clips to {bpm:.1f} BPM, match energy progression from calm intro to intense climax. Use {top_style} aesthetic throughout. {"Include lip-synced vocals on " + str(lipsync_clips) + " face clips." if lipsync_clips > 0 else ""}"""
        else:
            preview = f"""AI Director takes your vision: "{user_vision}"

📹 ANALYZING YOUR CONTENT:
   • {total_clips} clips: {top_subject} themed
   • Style: {top_style}
   • Energy range: {min(energies) if energies else 0}-{max(energies) if energies else 0}/10

🎵 MUSIC SYNC:
   • {bpm:.1f} BPM structure
   • {duration:.1f} second duration

🎬 ENHANCED VISION:
Will take "{user_vision}" and execute using detected {top_subject} content with {top_style} aesthetic, perfectly synced to {bpm:.1f} BPM. {f"Emphasize lip sync on {lipsync_clips} suitable clips during vocals." if lipsync_clips > 0 else ""}"""
        
        self.prompt_preview.setPlainText(preview)
        print(f'Preview shown: {total_clips} clips, {bpm:.1f} BPM')
        print('='*60 + '\n')
    
    def update_cost(self):
        base = 5
        lipsync_count = 3
        lipsync = lipsync_count * 10 if self.lipsync_checkbox.isChecked() else 0
        total = base + lipsync
        
        self.cost_total.setText(f'Total: {total} credits')
        self.cost_breakdown.setText(f'Analysis: ✓ | AI: {base} | Lip Sync: {lipsync}')
        self.generate_btn.setText(f'🎬 Generate Music Video ({total} credits)')
    
    def generate(self):
        print('\n' + '='*80)
        print('🎬 STAGE 2: CLAUDE AI DIRECTOR - CREATING EDIT PLAN')
        print('='*80)
        
        # Show progress
        self.progress_group.setVisible(True)
        self.generate_btn.setEnabled(False)
        self.progress_label.setText('Step 1/3: Gathering video analysis...')
        self.progress_bar.setValue(10)
        
        # Get data from parent tabs
        video_analyses = self._get_video_analyses()
        music_analysis = self._get_music_analysis()
        
        self.progress_label.setText('Step 2/3: Calling Claude AI Director...')
        self.progress_bar.setValue(30)
        
        # Build config
        user_config = {
            'mode': 'Auto' if self.auto_mode.isChecked() else 'Custom',
            'vision': self.vision_input.toPlainText().strip(),
            'style': ['Fast', 'Balanced', 'Cinematic'][self.style_group.checkedId()-1],
            'energy': self.energy.value(),
            'lipsync': self.lipsync_checkbox.isChecked()
        }
        
        print(f'\n📋 Configuration:')
        print(f'   Mode: {user_config["mode"]}')
        print(f'   Vision: {user_config["vision"] if user_config["vision"] else "Auto"}')
        print(f'   Videos: {len(video_analyses)} analyzed')
        print(f'   Music: {music_analysis.get("tempo", 0)} BPM, {music_analysis.get("duration", 0)}s')
        
        # CALL CLAUDE AI DIRECTOR
        edit_plan = self.director.create_edit_plan(video_analyses, music_analysis, user_config)
        
        self.progress_label.setText('Step 3/3: Sending to timeline...')
        self.progress_bar.setValue(90)
        
        # Emit to main window
        self.video_generated.emit(edit_plan)
        
        self.progress_bar.setValue(100)
        self.progress_label.setText(f'✅ Complete! {len(edit_plan.get("clips", []))} clips arranged')
        self.generate_btn.setEnabled(True)
        
        print('\n' + '='*80)
        print(f'✅ EDIT PLAN CREATED: {len(edit_plan.get("clips", []))} clips')
        print(f'   Vision: {edit_plan.get("creative_vision", "N/A")}')
        print('='*80 + '\n')
    
    def _get_video_analyses(self):
        """Get video analysis data from import tab"""
        if self.parent_window and hasattr(self.parent_window, 'import_tab'):
            return self.parent_window.import_tab.get_video_data()
        return {}
    
    def _get_music_analysis(self):
        """Get music analysis from music tab"""
        if self.parent_window and hasattr(self.parent_window, 'music_tab'):
            return self.parent_window.music_tab.get_analysis_data()
        return {'tempo': 120, 'duration': 180, 'beats': []}





