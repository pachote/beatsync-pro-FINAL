        self._checked = False

        self._hovered = False

        

        layout = QVBoxLayout(self)

        layout.setContentsMargins(14, 8, 14, 8)

        layout.setSpacing(2)

        

        title_label = QLabel(title)

        title_label.setStyleSheet(f"""

