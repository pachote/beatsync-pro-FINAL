                'Clean': 'clean',
                'Glitch': 'glitch',
                'Glitch Storm': 'glitch_storm',
                'Subtle': 'subtle',
                'Cinematic': 'cinematic',
                'Music Video': 'music_video',
                'Experimental': 'experimental',
                'Retro': 'retro'
            }
            
            # Convert editing preset name
            editing_backend = preset_map.get(editing, 'balanced')
            
            # Load full preset data from EditingPreset
            from core.editing_presets import EditingPreset
            preset_data = EditingPreset.get_preset(editing_backend)
            
            preset = {
                'editing': editing_backend,
                'color': color,
                'effects': effects,
                'clip_mix': preset_data.get('clip_mix', {'short': 0.4, 'medium': 0.4, 'long': 0.2}),
                'duration_range': preset_data.get('duration_range', (2.0, 4.0))
            }
            
            agi = AGIDirectorIntelligence(preset, audio_analysis)
            edit_plan = agi.create_edit_plan(analyzed_clips, beat_segments, audio_analysis.get('duration', 30))
            
            print(f"âœ… Edit plan created: {len(edit_plan)} cuts")
            
            if progress.wasCanceled():
                return
            
            # Step 5: Render video with FFmpeg
            progress.setLabelText("Rendering final video...")
            progress.setValue(80)
            
            output_dir = Path.home() / "Videos" / "BeatSync"
            output_dir.mkdir(parents=True, exist_ok=True)
            
            from datetime import datetime
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            output_path = output_dir / f"beatsync_{timestamp}.mp4"
            
            renderer = VideoRenderer()
            
            # Format edit plan for renderer (BUG FIX #2: Include effects!)
            edit_plan_formatted = {
                'clips': edit_plan,
                'color': color,
                'effects': effects  # NOW PASSING EFFECTS!
            }
            
            renderer.render_music_video(edit_plan_formatted, selected_audio, str(output_path))
            
            progress.setValue(100)
            progress.close()
            
            # Success!
            print(f"\nâœ… VIDEO COMPLETE: {output_path}")
            
            msg = f"ðŸŽ‰ Video Generated!\n\n"
            msg += f"Output: {output_path.name}\n"
            msg += f"Clips: {len(edit_plan)}\n"
            msg += f"Style: {editing} / {color} / {effects}\n\n"
            msg += f"Location: {output_dir}"
            
            result = QMessageBox.information(
                self, 
                "Success!", 
                msg,
                QMessageBox.Open | QMessageBox.Ok
            )
            
            if result == QMessageBox.Open:
                import subprocess
                subprocess.run(['explorer', str(output_dir)])
        
        except Exception as e:
            print(f"\nâŒ ERROR: {e}")
            import traceback
            traceback.print_exc()
            QMessageBox.critical(self, "Error", f"Video generation failed:\n\n{str(e)}")
