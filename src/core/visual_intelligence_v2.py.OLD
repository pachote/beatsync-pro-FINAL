import anthropic
import cv2
import base64
import json
import os
from pathlib import Path
import numpy as np
from PIL import Image
import io
import time
import sys
import re
import asyncio
sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), '../..')))
from config import CLAUDE_API_KEY
from .segment_quality_analyzer import segment_quality_analyzer

class VisualIntelligenceV2:
    def __init__(self, api_key=None):
        self.api_key = api_key or CLAUDE_API_KEY
        self.client = anthropic.Anthropic(api_key=self.api_key)
        self.cache = {}
        self.last_api_call = 0
        self.min_delay = 4.0  # INCREASED to 4 seconds between calls
        self.calls_this_minute = 0
        self.minute_start = time.time()
        self.max_calls_per_minute = 8  # Maximum 8 videos per minute
    
    def analyze_video(self, video_path):
        cache_key = f'{video_path}_{os.path.getmtime(video_path)}'
        if cache_key in self.cache:
            print(f'  [CACHE] {Path(video_path).name}')
            return self.cache[cache_key]
        
        # RATE LIMITING - Check if we need to wait for next minute
        current_time = time.time()
        time_in_minute = current_time - self.minute_start
        
        if time_in_minute >= 60:
            # Reset counter for new minute
            self.minute_start = current_time
            self.calls_this_minute = 0
        elif self.calls_this_minute >= self.max_calls_per_minute:
            # Wait until next minute
            wait_time = 60 - time_in_minute
            print(f'  [RATE LIMIT] Max calls reached. Waiting {wait_time:.0f}s for next minute...')
            time.sleep(wait_time)
            self.minute_start = time.time()
            self.calls_this_minute = 0
        
        # Additional delay between calls
        time_since_last = current_time - self.last_api_call
        if time_since_last < self.min_delay:
            wait_time = self.min_delay - time_since_last
            time.sleep(wait_time)
        
        print(f'  [CLAUDE AI] Analyzing {Path(video_path).name}...')
        
        try:
            frames = self._extract_key_frames(video_path, n=3)
            if not frames:
                return self._get_default_analysis()
            
            technical = self._get_technical_metadata(video_path)
            semantic = self._analyze_with_claude(frames)
            
            result = {**technical, **semantic, 'filename': Path(video_path).name}
            self.cache[cache_key] = result
            self.last_api_call = time.time()
            self.calls_this_minute += 1
            
            lip_sync = '🎤' if result.get('lip_sync_suitable') else ''
            print(f'  ✅ {lip_sync} {result.get("subject_type")} | {result.get("art_style")} | Energy: {result.get("energy_level")}/10')
            segment_quality = segment_quality_analyzer.analyze_video_segments(video_path)
            result["segment_quality"] = segment_quality
            return result
        except Exception as e:
            print(f'  [ERROR] {e}')
            self.last_api_call = time.time()
            return self._get_default_analysis()
    
    def _extract_key_frames(self, video_path, n=3):
        try:
            cap = cv2.VideoCapture(video_path)
            if not cap.isOpened():
                return []
            total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
            if total_frames == 0:
                return []
            indices = np.linspace(0, total_frames - 1, n, dtype=int)
            frames = []
            for idx in indices:
                cap.set(cv2.CAP_PROP_POS_FRAMES, idx)
                ret, frame = cap.read()
                if ret:
                    frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                    h, w = frame_rgb.shape[:2]
                    if max(h, w) > 600:
                        scale = 600 / max(h, w)
                        frame_rgb = cv2.resize(frame_rgb, (int(w*scale), int(h*scale)))
                    frames.append(frame_rgb)
            cap.release()
            return frames
        except:
            return []
    
    def _encode_frame_to_base64(self, frame):
        pil_img = Image.fromarray(frame)
        buf = io.BytesIO()
        pil_img.save(buf, format='JPEG', quality=70)
        return base64.b64encode(buf.getvalue()).decode('utf-8')
    
    def _analyze_with_claude(self, frames):
        content = [{
            'type': 'text',
            'text': 'Analyze these video frames. Return valid JSON with: subject_type, gender, age_range, art_style, environment, dominant_colors (array), energy_level (1-10), emotional_tone, is_ai_generated (boolean), objects_present (array), face_visible, mouth_visible, lip_sync_suitable (boolean). Be concise.'
        }]
        
        for frame in frames:
            content.append({'type': 'image', 'source': {'type': 'base64', 'media_type': 'image/jpeg', 'data': self._encode_frame_to_base64(frame)}})
        
        try:
            response = self.client.messages.create(
                model='claude-sonnet-4-20250514',
                max_tokens=512,
                messages=[{'role': 'user', 'content': content}]
            )
            
            text = response.content[0].text.strip()
            
            if '`json' in text:
                json_match = re.search(r'`json\s*(\{.*?\})\s*`', text, re.DOTALL)
                if json_match:
                    text = json_match.group(1)
            elif '`' in text:
                parts = text.split('`')
                if len(parts) >= 2:
                    text = parts[1].strip()
            
            text = text.replace('json', '').strip()
            result = json.loads(text)
            return result
            
        except anthropic.RateLimitError as e:
            print(f'  [RATE LIMIT] {e}')
            time.sleep(10)  # Wait 10 seconds on rate limit
            return {}
        except json.JSONDecodeError as e:
            print(f'  [JSON ERROR] {e}')
            return {}
        except Exception as e:
            print(f'  [API ERROR] {type(e).__name__}: {e}')
            return {}
    
    def _get_technical_metadata(self, video_path):
        try:
            cap = cv2.VideoCapture(video_path)
            fps = cap.get(cv2.CAP_PROP_FPS)
            fc = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
            w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
            h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
            dur = fc / fps if fps > 0 else 0
            cap.release()
            return {'resolution': f'{w}x{h}', 'fps': round(fps, 2), 'duration': round(dur, 2), 'frame_count': fc}
        except:
            return {'resolution': 'unknown', 'fps': 0, 'duration': 0, 'frame_count': 0}
    
    def _get_default_analysis(self):
        return {
            'subject_type': 'unknown', 'gender': 'none', 'age_range': 'none', 'person_count': 0,
            'art_style': 'unknown', 'environment': 'unknown', 'dominant_colors': [],
            'energy_level': 5, 'emotional_tone': 'neutral', 'is_ai_generated': False,
            'objects_present': [], 'face_visible': False, 'mouth_visible': False,
            'lip_sync_suitable': False, 'resolution': 'unknown', 'fps': 0, 'duration': 0
        }


