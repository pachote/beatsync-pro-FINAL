@dataclass
class ClipAnalysis:
    """Complete analysis of a single video clip"""
    video_path: str
    duration: float
    
    # Visual attributes (from Claude Vision API)
    subject_type: str  # 'person', 'landscape', 'abstract', etc.
    has_faces: bool
    face_count: int
    art_style: str  # 'realistic', 'animated', 'abstract', etc.
    color_dominant: str  # Hex color of dominant hue
    color_palette: List[str]  # Top 5 colors
    motion_intensity: float  # 0-10 scale
    composition: str  # 'close_up', 'medium', 'wide', etc.
    energy_level: float  # 0-10 scale
    mood: str  # 'happy', 'dramatic', 'calm', etc.
    
    # Technical attributes
    resolution: Tuple[int, int]
    fps: float
    codec: str


@dataclass
class BeatSegment:
    """Analysis of music segment between beats"""
    start_time: float
    end_time: float
    duration: float
    beat_index: int
    
    # Audio characteristics
    energy: float  # RMS energy 0-1
    spectral_flux: float  # Change in frequency content
    is_drop: bool  # Major drop/peak
    is_buildup: bool  # Building tension
    has_vocals: bool  # Vocal presence detected
    tempo: float  # BPM at this segment


