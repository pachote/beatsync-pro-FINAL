def create_genius_edit_plan(
    editing_preset: Dict,
    audio_analysis: Dict,
    available_clips: List[ClipAnalysis],
    beat_segments: List[BeatSegment],
    total_duration: float
) -> List[Dict]:
    """
    Convenience function to create genius edit plan
    
    Args:
        editing_preset: From multi_preset_system
        audio_analysis: Audio analysis data
        available_clips: All analyzed clips
        beat_segments: Beat-segmented timeline
        total_duration: Target video length
    
    Returns:
        Complete edit plan with genius optimizations
    """
    director = AGIDirectorIntelligence(editing_preset, audio_analysis)
    edit_plan = director.create_edit_plan(available_clips, beat_segments, total_duration)
    
    return edit_plan
