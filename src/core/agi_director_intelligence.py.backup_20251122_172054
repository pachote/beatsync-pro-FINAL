        print(f"  TARGET: {target_clips} clips for {total_duration:.1f}s (preset: {preset_name})")
        
        # PHASE 2: Loop through target clips, not beat segments!
        i = 0
        safety_limit = 500  # Prevent infinite loops
        while current_time < total_duration and i < safety_limit:
            if current_time >= total_duration:
                break
            
            # Find relevant beat segment for this clip
            segment_idx = min(int(i * len(beat_segments) / max(1, len(beat_segments))), len(beat_segments) - 1)
            segment = beat_segments[segment_idx]
            
            # Calculate desired clip duration based on preset AND context
            clip_duration = self._calculate_genius_clip_duration(
                segment, 
                i, 
                len(beat_segments),
                emotional_arc
            )
            
            # Select PERFECT clip using 10-factor analysis
            selected_clip = self._select_genius_clip(
                available_clips,
                segment,
                clip_duration,
                emotional_arc[i],
                edit_plan
            )
            
            if selected_clip is None:
                continue
            
            # Calculate trim point with variety
            trim_start = self._calculate_smart_trim(
                selected_clip,
                clip_duration
            )
            
            # Determine speed variation
            speed_multiplier = self._calculate_speed_variation(
                selected_clip,
                segment,
                emotional_arc[i]
            )
            
            # Determine transition type
            transition = self._select_intelligent_transition(
                edit_plan,
                selected_clip,
                segment
            )
            
            # Build clip plan
            clip_plan = {
                'video_path': selected_clip.video_path,
                'start_time': current_time,
                'end_time': current_time + clip_duration,
                'duration': clip_duration,
                'trim_start': trim_start,
                'trim_end': trim_start + clip_duration,
                'speed': speed_multiplier,
