    def _analyze_emotional_arc(self, beat_segments: List[BeatSegment]) -> List[float]:
        """
        Analyze the emotional arc of the entire song
        
        Returns emotional intensity curve (0-10) for each segment
        This guides strategic pacing decisions
        """
        curve = []
        
        for i, segment in enumerate(beat_segments):
            # Base intensity from audio energy
            intensity = segment.energy * 10
            
            # Boost at drops
            if segment.is_drop:
                intensity = min(10.0, intensity * 1.5)
            
            # Lower during buildups (creates tension)
            if segment.is_buildup:
                intensity *= 0.7
            
            # Apply smoothing (avoid jarring jumps)
            if i > 0:
                prev_intensity = curve[-1]
                intensity = (intensity + prev_intensity) / 2
            
            curve.append(intensity)
        
        return curve
    
    def _calculate_genius_clip_duration(
        self,
        segment: BeatSegment,
        segment_index: int,
        total_segments: int,
        emotional_arc: List[float]
    ) -> float:
        """
        Calculate duration with PRESET DOMINANCE
        
        FIX: Preset durations are PRIMARY, musical intelligence is SUBTLE adjustment
        """
        import random
        
        emotional_intensity = emotional_arc[segment_index]
        progress = segment_index / max(1, total_segments - 1)
        is_intro = progress < 0.10
        is_outro = progress > 0.90
        
        # STEP 1: Get BASE duration - STRICTLY from preset!
        clip_mix = self.clip_mix
        
        ultra_short_weight = clip_mix.get('ultra_short', 0)
        short_weight = clip_mix.get('short', 0)
        medium_weight = clip_mix.get('medium', 0)
        long_weight = clip_mix.get('long', 0)
        
        # Hypercut should have: ultra_short=55%, short=30%, medium=15%
        
        categories = ['ultra_short', 'short', 'medium', 'long']
        weights = [ultra_short_weight, short_weight, medium_weight, long_weight]
        
        selected_category = random.choices(categories, weights=weights, k=1)[0]
        
        # STRICT preset durations - NO flexibility!
        if selected_category == 'ultra_short':
            base_duration = random.uniform(0.3, 0.7)  # Hypercut range
        elif selected_category == 'short':
            base_duration = random.uniform(0.7, 1.2)
        elif selected_category == 'medium':
            base_duration = random.uniform(1.2, 2.0)
        else:
            base_duration = random.uniform(2.0, 4.0)
        
        # STEP 2: MICRO adjustments only (±10% max!)
        
        if segment.is_drop or emotional_intensity > 8.5:
            # DROP = Slightly faster
            multiplier = random.uniform(0.95, 1.0)
        elif is_intro or is_outro:
            # INTRO/OUTRO = Slightly slower (but NOT 2x!)
            multiplier = random.uniform(1.0, 1.1)
        else:
            # Everything else = Base speed
            multiplier = 1.0
        
        final_duration = base_duration * multiplier
        
        return round(final_duration, 2)
