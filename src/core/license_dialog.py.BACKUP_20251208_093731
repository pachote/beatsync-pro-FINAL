"""
BeatSync PRO - License Activation Dialog
Shows on first launch or when license needs re-validation
"""
from PySide6.QtWidgets import (QDialog, QVBoxLayout, QHBoxLayout, QLabel, 
                              QLineEdit, QPushButton, QFrame, QMessageBox)
from PySide6.QtCore import Qt, QThread, Signal
from PySide6.QtGui import QFont

class ValidationThread(QThread):
    """Background thread for license validation"""
    finished = Signal(dict)
    
    def __init__(self, api, license_key):
        super().__init__()
        self.api = api
        self.license_key = license_key
    
    def run(self):
        result = self.api.validate_license(self.license_key)
        self.finished.emit(result)

class LicenseDialog(QDialog):
    """License activation dialog"""
    
    def __init__(self, api, license_manager, parent=None):
        super().__init__(parent)
        self.api = api
        self.license_manager = license_manager
        self.validated = False
        self.validation_thread = None
        self.setup_ui()
        
    def setup_ui(self):
        self.setWindowTitle("BeatSync PRO - License Activation")
        self.setFixedSize(500, 380)
        self.setModal(True)
        
        # Dark theme styling
        self.setStyleSheet("""
            QDialog {
                background-color: #1a1a2e;
                color: #ffffff;
            }
            QLabel {
                color: #ffffff;
            }
            QLineEdit {
                background-color: #16213e;
                border: 2px solid #0f3460;
                border-radius: 8px;
                padding: 12px;
                color: #ffffff;
                font-size: 14px;
            }
            QLineEdit:focus {
                border-color: #e94560;
            }
            QPushButton {
                background-color: #e94560;
                color: white;
                border: none;
                border-radius: 8px;
                padding: 12px 24px;
                font-size: 14px;
                font-weight: bold;
            }
            QPushButton:hover {
                background-color: #ff6b6b;
            }
            QPushButton:disabled {
                background-color: #555555;
            }
            QPushButton#exitBtn {
                background-color: transparent;
                border: 2px solid #555555;
                color: #888888;
            }
            QPushButton#exitBtn:hover {
                border-color: #e94560;
                color: #e94560;
            }
        """)
        
        layout = QVBoxLayout(self)
        layout.setSpacing(20)
        layout.setContentsMargins(40, 40, 40, 40)
        
        # Logo/Title
        title = QLabel("BeatSync PRO")
        title.setFont(QFont("Segoe UI", 24, QFont.Weight.Bold))
        title.setAlignment(Qt.AlignmentFlag.AlignCenter)
        title.setStyleSheet("color: #e94560;")
        layout.addWidget(title)
        
        # Subtitle
        subtitle = QLabel("Professional AI Music Video Creation")
        subtitle.setFont(QFont("Segoe UI", 11))
        subtitle.setAlignment(Qt.AlignmentFlag.AlignCenter)
        subtitle.setStyleSheet("color: #888888;")
        layout.addWidget(subtitle)
        
        layout.addSpacing(20)
        
        # Instructions
        instructions = QLabel("Enter your license key to activate:")
        instructions.setFont(QFont("Segoe UI", 12))
        layout.addWidget(instructions)
        
        # License key input
        self.key_input = QLineEdit()
        self.key_input.setPlaceholderText("XXXX-XXXX-XXXX-XXXX")
        self.key_input.setFont(QFont("Consolas", 14))
        self.key_input.textChanged.connect(self.on_text_changed)
        layout.addWidget(self.key_input)
        
        # Status label
        self.status_label = QLabel("")
        self.status_label.setFont(QFont("Segoe UI", 10))
        self.status_label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self.status_label.setStyleSheet("color: #888888;")
        layout.addWidget(self.status_label)
        
        layout.addStretch()
        
        # Buttons
        btn_layout = QHBoxLayout()
        
        self.exit_btn = QPushButton("Exit")
        self.exit_btn.setObjectName("exitBtn")
        self.exit_btn.clicked.connect(self.reject)
        btn_layout.addWidget(self.exit_btn)
        
        btn_layout.addStretch()
        
        self.activate_btn = QPushButton("Activate License")
        self.activate_btn.setEnabled(False)
        self.activate_btn.clicked.connect(self.validate_license)
        btn_layout.addWidget(self.activate_btn)
        
        layout.addLayout(btn_layout)
        
        # Purchase link
        purchase = QLabel('<a href="https://beatsyncpro.ai" style="color: #e94560;">Don\'t have a license? Purchase here</a>')
        purchase.setOpenExternalLinks(True)
        purchase.setAlignment(Qt.AlignmentFlag.AlignCenter)
        layout.addWidget(purchase)
    
    def on_text_changed(self, text):
        """Enable button when text entered"""
        self.activate_btn.setEnabled(len(text.strip()) >= 8)
        self.status_label.setText("")
        self.status_label.setStyleSheet("color: #888888;")
    
    def validate_license(self):
        """Validate the entered license key"""
        license_key = self.key_input.text().strip()
        if not license_key:
            return
        
        self.activate_btn.setEnabled(False)
        self.key_input.setEnabled(False)
        self.status_label.setText("Validating license...")
        self.status_label.setStyleSheet("color: #4ecdc4;")
        
        # Run validation in background thread
        self.validation_thread = ValidationThread(self.api, license_key)
        self.validation_thread.finished.connect(self.on_validation_complete)
        self.validation_thread.start()
    
    def on_validation_complete(self, result):
        """Handle validation result"""
        self.key_input.setEnabled(True)
        
        if result.get("success"):
            # Save license locally
            self.license_manager.save_license(
                self.key_input.text().strip(),
                self.api.email or "",
                self.api.tier or ""
            )
            self.status_label.setText("? License activated successfully!")
            self.status_label.setStyleSheet("color: #4ecdc4;")
            self.validated = True
            
            # Close dialog after brief delay
            from PySide6.QtCore import QTimer
            QTimer.singleShot(1000, self.accept)
        else:
            error = result.get("error", "Validation failed")
            self.status_label.setText(f"? {error}")
            self.status_label.setStyleSheet("color: #e94560;")
            self.activate_btn.setEnabled(True)
    
    def was_validated(self):
        """Check if license was successfully validated"""
        return self.validated
