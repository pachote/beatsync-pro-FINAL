import librosa
import numpy as np
import os
from . import audio_reactive_engine

class AudioAnalyzer:
    def __init__(self):
        print("Auditory Cortex expert is online.")

    def detect_beat_types(self, y, sr, beat_times):
        """
        Detect specific beat types: hi-hats, snares, kicks, bass
        Returns dict with arrays of timestamps for each beat type
        """
        print("  ??? Detecting beat types (hi-hats, snares, kicks, bass)...")
        
        # Get spectral data
        S = np.abs(librosa.stft(y))
        freqs = librosa.fft_frequencies(sr=sr)
        
        # Frequency ranges
        BASS_RANGE = (20, 80)      # Deep bass
        KICK_RANGE = (50, 150)     # Kick drum
        SNARE_RANGE = (150, 500)   # Snare drum
        HIHAT_RANGE = (6000, 18000) # Hi-hats (crispy high)
        
        beat_types = {
            'hi_hats': [],
            'snares': [],
            'kicks': [],
            'bass': []
        }
        
        # Analyze each beat
        for beat_time in beat_times:
            frame = librosa.time_to_frames(beat_time, sr=sr)
            if frame >= S.shape[1]:
                continue
                
            # Get energy in each frequency range
            bass_mask = (freqs >= BASS_RANGE[0]) & (freqs < BASS_RANGE[1])
            kick_mask = (freqs >= KICK_RANGE[0]) & (freqs < KICK_RANGE[1])
            snare_mask = (freqs >= SNARE_RANGE[0]) & (freqs < SNARE_RANGE[1])
            hihat_mask = (freqs >= HIHAT_RANGE[0]) & (freqs < HIHAT_RANGE[1])
            
            bass_energy = np.mean(S[bass_mask, frame]) if np.any(bass_mask) else 0
            kick_energy = np.mean(S[kick_mask, frame]) if np.any(kick_mask) else 0
            snare_energy = np.mean(S[snare_mask, frame]) if np.any(snare_mask) else 0
            hihat_energy = np.mean(S[hihat_mask, frame]) if np.any(hihat_mask) else 0
            
            # Normalize energies
            total = bass_energy + kick_energy + snare_energy + hihat_energy + 1e-6
            bass_ratio = bass_energy / total
            kick_ratio = kick_energy / total
            snare_ratio = snare_energy / total
            hihat_ratio = hihat_energy / total
            
            # Classify based on dominant frequency
            if hihat_ratio > 0.15:
                beat_types['hi_hats'].append(float(beat_time))
            if snare_ratio > 0.25:
                beat_types['snares'].append(float(beat_time))
            if kick_ratio > 0.3:
                beat_types['kicks'].append(float(beat_time))
            if bass_ratio > 0.3:
                beat_types['bass'].append(float(beat_time))
        
        print(f"     ?? Hi-hats: {len(beat_types['hi_hats'])}")
        print(f"     ?? Snares: {len(beat_types['snares'])}")
        print(f"     ?? Kicks: {len(beat_types['kicks'])}")
        print(f"     ?? Bass: {len(beat_types['bass'])}")
        
        return beat_types

    def analyze_music(self, audio_path):
        try:
            print(f"Auditory Cortex: Analyzing '{os.path.basename(audio_path)}'...")
            y, sr = librosa.load(audio_path, sr=None)

            # 1. Beat and Tempo Analysis
            tempo, beats = librosa.beat.beat_track(y=y, sr=sr, units='time')

            # 2. Structural Segmentation (Corrected & Simplified Logic)
            chroma = librosa.feature.chroma_cqt(y=y, sr=sr)
            bounds = librosa.segment.agglomerative(chroma, k=10)
            segment_times = librosa.frames_to_time(bounds, sr=sr)
            segment_times = np.concatenate(([0], segment_times, [librosa.get_duration(y=y, sr=sr)]))

            segments = []
            structure_map = ['Intro', 'Verse', 'Chorus', 'Verse', 'Chorus', 'Bridge', 'Chorus', 'Solo', 'Chorus', 'Outro']
            for i in range(len(segment_times) - 1):
                segments.append({
                    "label": structure_map[i % len(structure_map)],
                    "start": segment_times[i],
                    "end": segment_times[i+1]
                })

            # 3. Energy Analysis
            rms = librosa.feature.rms(y=y)[0]
            times = librosa.times_like(rms, sr=sr)
            rms_normalized = rms / (np.max(rms) + 1e-6)
            energy_map = [{"time": float(t), "energy": float(e)} for t, e in zip(times, rms_normalized)]

            beat_map = {
                'tempo': float(tempo),
                'duration': float(librosa.get_duration(y=y, sr=sr)),
                'beat_times': beats.tolist(),
                'segments': segments,
                'energy_map': energy_map
            }
            print("Auditory Cortex: Analysis complete.")

            # BEAT-LEVEL DETECTION
            beat_types = self.detect_beat_types(y, sr, beats)
            beat_map["beat_types"] = beat_types
            
            # AUDIO REACTIVE EFFECTS
            audio_reactive = audio_reactive_engine.analyze_for_effects(audio_path, beat_map)
            beat_map["audio_reactive"] = audio_reactive

            return beat_map
        except Exception as e:
            print(f"ERROR in Auditory Cortex: {e}")
            return None
